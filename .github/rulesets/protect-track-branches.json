{
  "name": "Protect track branches",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": [
        "refs/heads/track-a",
        "refs/heads/track-b",
        "refs/heads/track-c"
      ],
      "exclude": []
    }
  },
  "rules": [{ "type": "deletion" }, { "type": "non_fast_forward" }],
  "bypass_actors": []
}
