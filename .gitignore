__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
build/
*.so
*.dll
*.dylib
# T1.0: corpora and generated data are fetched, never vendored.
# DECISION: manifest.json is the tracked T0.1 artifact, so it is re-included
# explicitly; work order specified a bare `data/` ignore.
# DECISION (T2.1, Track B — flagged to Track A): the hand-curated clause records
# under data/regulations/*.jsonl are authored source, not fetched data, and
# CLAUDE.md's Layout section designates data/regulations/ as tracked Track B
# clause records. So ignore the *contents* of data/ (`data/*`) and re-include the
# authored artifacts, while keeping data/corpora/, data/benchmark/, and the
# archived-PDF data/regulations/sources/ (T2.5) ignored.
data/*
!data/manifest.json
!data/regulations/
data/regulations/*
!data/regulations/*.jsonl
# T2.5: the regulation source archive. Track the sha256 pin-manifest + README
# always; the primary PDFs themselves are tracked too (user directive: keep them
# in the repo). Flip the *.pdf line back to ignored if repo size becomes a concern
# — MANIFEST.json still pins them by hash either way.
!data/regulations/sources/
data/regulations/sources/*
!data/regulations/sources/MANIFEST.json
!data/regulations/sources/README.md
!data/regulations/sources/*.pdf
# T2.2/T2.3: native mutation bases are authored source, not generated output.
# Keep other data/benchmark products ignored unless they are already tracked.
!data/benchmark/
data/benchmark/*
!data/benchmark/seed/
data/benchmark/seed/*
!data/benchmark/seed/programs/
data/benchmark/seed/programs/*
!data/benchmark/seed/programs/*.cbl
!data/benchmark/seed/programs/*.cpy
!data/benchmark/seed/base_roster.json
!data/benchmark/seed/programs/train-bases/
!data/benchmark/seed/programs/train-bases/*.cbl
!data/benchmark/seed/programs/train-bases/*.cpy
!data/benchmark/seed/programs/test-bases-x/
!data/benchmark/seed/programs/test-bases-x/*.cbl
!data/benchmark/seed/programs/test-bases-x/*.cpy
# T2.4/T2.6: canonical judgement evidence and v1-pre splits are deliverables.
!data/benchmark/judgements.jsonl
!data/benchmark/judgements.sample50.jsonl
!data/benchmark/t2_7_plausibility.jsonl
!data/benchmark/judge_overrides.jsonl
!data/benchmark/drift_instances.plausible.jsonl
!data/benchmark/unsure_adjudications.jsonl
!data/benchmark/human_review.sample15.jsonl
!data/benchmark/rejected/
data/benchmark/rejected/*
!data/benchmark/rejected/implausible.jsonl
!data/benchmark/rejected/unsure.jsonl
!data/benchmark/v1-pre/
!data/benchmark/v1-pre/*.jsonl
!data/benchmark/v1-pre/distribution.md
.venv/
.venv312/
*.egg-info/
# T3.2: local model-weight cache (pinned embedder + reranker). Never vendored.
.model_cache/
